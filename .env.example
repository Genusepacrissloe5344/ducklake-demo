# AWS — uses SSO credential chain, no keys needed for setup.py
# For dbt, export temp creds: eval $(aws configure export-credentials --profile gmds --format env)
AWS_PROFILE=
AWS_REGION=
S3_BUCKET=
S3_PATH=ducklake

# PostgreSQL (Neon)
PG_URL=postgresql://user:password@host/neondb?sslmode=require

# dbt connection string (libpq format, used in profiles.yml)
PG_CONN=dbname=neondb host=your-host port=5432 user=your-user password=your-pass sslmode=require
