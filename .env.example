# AWS — uses SSO credential chain
AWS_PROFILE=
AWS_REGION=
S3_BUCKET=

# Single-player mode: set to "true" to use SQLite, false to use Postgres.
# No database setup needed — just AWS credentials and an S3 bucket.
SINGLE_PLAYER=true

# ── Multiplayer only (ignored when SINGLE_PLAYER=true) ──────────────
# S3_PATH defaults to "ducklake" (multiplayer) or "ducklake-sp" (single-player)
# S3_PATH=ducklake

# PostgreSQL (Neon)
PG_URL=postgresql://user:password@host/neondb?sslmode=require

# dbt connection string (libpq format, used in profiles.yml)
PG_CONN=dbname=neondb host=your-host port=5432 user=your-user password=your-pass sslmode=require
